# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Database Configuration
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=fund_app
MYSQL_USER=fund_user
MYSQL_PASSWORD=your_mysql_password

# Service URLs
DATABASE_URL=mysql+pymysql://fund_user:your_mysql_password@mysql:3306/fund_app
REDIS_URL=redis://redis:6379

# JWT Configuration (MUST be a strong random secret)
JWT_SECRET=your_jwt_secret_key_here_generate_with_openssl_rand_base64_32

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASS=your_rabbitmq_password
