# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Database Configuration
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=fund_app
MYSQL_USER=fund_user
MYSQL_PASSWORD=fund_pass
DATABASE_URL=mysql+pymysql://fund_user:fund_pass@mysql:3306/fund_app

# Redis Configuration
REDIS_URL=redis://redis:6379

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# JWT Configuration (IMPORTANT: Change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Service Ports
AUTH_SERVICE_PORT=8001
ACCOUNT_SERVICE_PORT=8002
FUND_SERVICE_PORT=8003
PORTFOLIO_SERVICE_PORT=8004
TRADE_SERVICE_PORT=8005
